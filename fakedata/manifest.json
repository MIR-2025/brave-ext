{
  "manifest_version": 3,
  "name": "FakeData -- smart form filler",
  "version": "1.0.0",
  "description": "Fill any form with realistic, consistent fake data -- names, emails, addresses, cards, and more -- matched to each field. Fully local, nothing leaves your browser.",
  "permissions": ["activeTab", "scripting", "contextMenus", "storage"],
  "action": {
    "default_title": "FakeData",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": { "service_worker": "background.js" },
  "commands": {
    "fill": {
      "suggested_key": { "default": "Alt+Shift+F" },
      "description": "Fill the page with fake data"
    }
  }
}
