{
  "manifest_version": 3,
  "name": "Tab Overview -- visual grid of open tabs",
  "version": "1.1.0",
  "description": "See all your open tabs in one grid with thumbnails, per-tab JS heap, search, and one-click switch or close. Thumbnails are captured as you browse. Fully local.",
  "permissions": ["storage", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Tab Overview",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": { "service_worker": "background.js" }
}
