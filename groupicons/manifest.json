{
  "manifest_version": 3,
  "name": "Group Icons -- emoji labels for tab groups",
  "version": "1.0.0",
  "description": "Put an emoji icon on any tab group instead of a text label, and recolor groups. Fully local -- nothing leaves your browser.",
  "permissions": ["tabGroups", "tabs"],
  "action": {
    "default_title": "Group Icons",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
